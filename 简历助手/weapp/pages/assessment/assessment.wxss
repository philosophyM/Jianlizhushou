.page { padding: var(--gap-md); min-height: 100vh; display: flex; flex-direction: column; }

/* 进度条 */
.progress-bar { margin-bottom: var(--gap-lg); }
.progress-track { height: 8rpx; background: var(--border-light); border-radius: 4rpx; overflow: hidden; margin-bottom: 8rpx; }
.progress-fill { height: 100%; background: linear-gradient(90deg, var(--primary), var(--secondary)); border-radius: 4rpx; transition: width 0.3s ease; }
.progress-text { font-size: 24rpx; color: var(--text-tertiary); text-align: right; }

/* 题目卡片 */
.question-card {
  background: white;
  border-radius: var(--radius-lg);
  padding: var(--gap-lg);
  box-shadow: var(--shadow-md);
  flex: 1;
}

.question-section {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
  margin-bottom: var(--gap-sm);
}

.question-text {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: var(--gap-lg);
}

.option-group { display: flex; flex-direction: column; gap: var(--gap-sm); }

.option-item {
  display: flex;
  align-items: center;
  gap: var(--gap-md);
  padding: 28rpx var(--gap-md);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  transition: all 0.2s;
}

.option-item.active {
  border-color: var(--primary);
  background: rgba(74,108,247,0.05);
}

.option-dot {
  width: 28rpx; height: 28rpx;
  border-radius: 50%;
  border: 3rpx solid var(--border);
  transition: all 0.2s;
  flex-shrink: 0;
}

.option-dot.active {
  border-color: var(--primary);
  background: var(--primary);
  box-shadow: 0 0 0 4rpx rgba(74,108,247,0.2);
}

.option-text { font-size: 28rpx; color: var(--text-primary); }

.question-nav {
  display: flex;
  justify-content: space-between;
  margin-top: var(--gap-lg);
  gap: var(--gap-md);
}

.nav-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 600;
  background: var(--bg-primary);
  color: var(--text-secondary);
}

.nav-btn.primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: white;
}

/* 完成页面 */
.finish-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--gap-xl) 0;
  text-align: center;
}

.finish-icon { font-size: 100rpx; margin-bottom: var(--gap-lg); }
.finish-title { font-size: 40rpx; font-weight: 700; color: var(--text-primary); margin-bottom: var(--gap-md); }
.finish-desc { font-size: 28rpx; color: var(--text-secondary); margin-bottom: var(--gap-xl); line-height: 1.6; }
.btn-primary { background: linear-gradient(135deg, #4A6CF7, #3451D1); color: white; padding: 20rpx 64rpx; border-radius: 16rpx; font-size: 30rpx; font-weight: 600; }
