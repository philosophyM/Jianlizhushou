.page { padding: var(--gap-md); padding-bottom: 160rpx; }
.result-header { text-align: center; padding: var(--gap-lg) 0; }
.result-title { font-size: 44rpx; font-weight: 800; color: var(--text-primary); }
.result-subtitle { font-size: 26rpx; color: var(--text-secondary); margin-top: 12rpx; }
.card { background: white; border-radius: 16rpx; padding: var(--gap-md); margin-bottom: var(--gap-md); box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
.section-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); margin-bottom: var(--gap-md); padding-left: var(--gap-sm); border-left: 6rpx solid #4A6CF7; }

/* 推荐列表 */
.recommend-list { display: flex; flex-direction: column; gap: var(--gap-sm); }
.recommend-item { display: flex; align-items: center; gap: var(--gap-md); padding: var(--gap-sm); background: var(--bg-primary); border-radius: var(--radius-md); }
.recommend-rank { width: 40rpx; height: 40rpx; background: linear-gradient(135deg, #4A6CF7, #7C3AED); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22rpx; font-weight: 700; flex-shrink: 0; }
.recommend-info { flex: 1; }
.recommend-career { font-size: 28rpx; font-weight: 600; color: var(--text-primary); display: block; }
.recommend-type { font-size: 22rpx; color: var(--text-tertiary); }
.recommend-score { display: flex; flex-direction: column; align-items: flex-end; gap: 4rpx; }
.score-num { font-size: 24rpx; font-weight: 700; color: #4A6CF7; }
.score-bar { width: 100rpx; height: 6rpx; background: var(--border-light); border-radius: 3rpx; overflow: hidden; }
.score-fill { height: 100%; background: linear-gradient(90deg, #4A6CF7, #10B981); border-radius: 3rpx; }

/* 霍兰德图表 */
.holland-chart { display: flex; flex-direction: column; gap: var(--gap-sm); }
.holland-bar { display: flex; align-items: center; gap: var(--gap-sm); }
.holland-label { width: 100rpx; font-size: 24rpx; color: var(--text-secondary); }
.holland-track { flex: 1; height: 24rpx; background: var(--border-light); border-radius: 12rpx; overflow: hidden; }
.holland-fill { height: 100%; background: linear-gradient(90deg, #4A6CF7, #7C3AED); border-radius: 12rpx; transition: width 0.5s ease; }
.holland-score { width: 40rpx; font-size: 22rpx; color: var(--primary); font-weight: 600; text-align: right; }
.holland-code { margin-top: var(--gap-md); text-align: center; }
.code-label { font-size: 26rpx; color: var(--text-secondary); }
.code-value { font-size: 48rpx; font-weight: 800; color: var(--primary); letter-spacing: 8rpx; }

/* 大五人格 */
.bigfive-list { display: flex; flex-direction: column; gap: var(--gap-md); }
.bigfive-item { }
.bigfive-header { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.bigfive-name { font-size: 26rpx; font-weight: 600; color: var(--text-primary); }
.bigfive-desc { font-size: 22rpx; color: var(--text-tertiary); flex: 1; text-align: right; }
.bigfive-track { height: 16rpx; background: var(--border-light); border-radius: 8rpx; overflow: hidden; }
.bigfive-fill { height: 100%; background: linear-gradient(90deg, #10B981, #4A6CF7); border-radius: 8rpx; transition: width 0.5s ease; }

/* 价值观 */
.values-list { display: flex; flex-wrap: wrap; gap: var(--gap-sm); }
.value-item { background: var(--bg-primary); padding: var(--gap-sm) var(--gap-md); border-radius: var(--radius-md); display: flex; align-items: center; gap: var(--gap-sm); }
.value-name { font-size: 26rpx; color: var(--text-primary); }
.value-tag { font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 12rpx; background: rgba(74,108,247,0.1); color: var(--primary); }

/* 操作栏 */
.action-bar { display: flex; gap: var(--gap-md); margin-top: var(--gap-lg); }
.btn-primary { flex: 1; height: 88rpx; background: linear-gradient(135deg, #4A6CF7, #3451D1); color: white; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 600; }
.btn-secondary { flex: 1; height: 88rpx; background: var(--bg-primary); color: var(--text-primary); border: 2rpx solid var(--border); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 600; }
