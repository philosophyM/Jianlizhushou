.page { padding-bottom: 120rpx; }
.container { padding: var(--gap-md); }
.hero-text { text-align: center; padding: var(--gap-lg) 0 var(--gap-md); }
.hero-title { font-size: 40rpx; font-weight: 700; color: var(--text-primary); display: block; }
.hero-desc { font-size: 26rpx; color: var(--text-secondary); margin-top: 12rpx; line-height: 1.5; }
.card { background: white; border-radius: 16rpx; padding: var(--gap-md); margin-bottom: var(--gap-md); box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
.section-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); margin-bottom: var(--gap-md); padding-left: var(--gap-sm); border-left: 6rpx solid #4A6CF7; }
.form-group { margin-bottom: var(--gap-md); }
.form-label { font-size: 28rpx; font-weight: 500; color: var(--text-primary); margin-bottom: var(--gap-xs); display: block; }

.jd-input {
  width: 100%;
  min-height: 400rpx;
  padding: var(--gap-md);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  font-size: 26rpx;
  background: var(--bg-secondary);
  box-sizing: border-box;
  line-height: 1.6;
}

.btn-primary { background: linear-gradient(135deg, #4A6CF7, #3451D1); color: white; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 600; }
.btn-large { width: 100%; height: 96rpx; font-size: 32rpx; }
.btn-secondary { background: var(--bg-primary); color: var(--text-primary); border: 2rpx solid var(--border); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 600; }

/* 分析中动画 */
.analyzing-state { display: flex; flex-direction: column; align-items: center; padding: var(--gap-xl) 0; }
.analyzing-animation { display: flex; gap: 16rpx; margin-bottom: var(--gap-lg); }
.pulse-circle { width: 24rpx; height: 24rpx; background: #4A6CF7; border-radius: 50%; animation: pulse 1.5s infinite; }
.pulse-circle.delay { animation-delay: 0.3s; }
.pulse-circle.delay2 { animation-delay: 0.6s; }
@keyframes pulse { 0%, 100% { opacity: 0.3; transform: scale(0.8); } 50% { opacity: 1; transform: scale(1.2); } }
.analyzing-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); margin-bottom: var(--gap-sm); }
.analyzing-desc { font-size: 26rpx; color: var(--text-tertiary); }

/* 匹配度 */
.match-card { background: linear-gradient(135deg, #1A1A2E, #16213E); border-radius: var(--radius-lg); padding: var(--gap-lg); text-align: center; margin-bottom: var(--gap-md); }
.match-title { font-size: 28rpx; color: rgba(255,255,255,0.7); margin-bottom: var(--gap-md); display: block; }
.match-score-ring { width: 200rpx; height: 200rpx; border-radius: 50%; border: 8rpx solid rgba(74,108,247,0.3); display: flex; flex-direction: column; align-items: center; justify-content: center; margin: 0 auto; position: relative; }
.score-ring-bg { position: absolute; width: 100%; height: 100%; border-radius: 50%; border: 8rpx solid transparent; border-top-color: #4A6CF7; border-right-color: #7C3AED; animation: rotate 2s linear; }
@keyframes rotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
.score-ring-value { font-size: 64rpx; font-weight: 800; color: white; }
.score-ring-label { font-size: 22rpx; color: rgba(255,255,255,0.6); }

/* 信息行 */
.info-row { display: flex; padding: var(--gap-sm) 0; border-bottom: 1rpx solid var(--border-light); }
.info-row:last-child { border-bottom: none; }
.info-label { width: 100rpx; font-size: 26rpx; color: var(--text-secondary); }
.info-value { flex: 1; font-size: 26rpx; color: var(--text-primary); font-weight: 500; }
.salary { color: #10B981; font-weight: 700; }

/* 关键词标签 */
.keywords { display: flex; flex-wrap: wrap; gap: var(--gap-xs); }
.tag-primary { display: inline-block; padding: 6rpx 20rpx; font-size: 22rpx; border-radius: 20rpx; background: rgba(74,108,247,0.1); color: #4A6CF7; }

/* 要求列表 */
.req-list { display: flex; flex-direction: column; gap: var(--gap-sm); }
.req-item { display: flex; gap: var(--gap-sm); }
.req-bullet { color: #4A6CF7; font-size: 28rpx; }
.req-text { font-size: 26rpx; color: var(--text-primary); line-height: 1.5; }

/* 匹配详情 */
.match-detail-item { display: flex; align-items: center; gap: var(--gap-md); padding: var(--gap-sm) 0; }
.detail-status { width: 36rpx; height: 36rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20rpx; font-weight: 700; }
.detail-status.match { background: rgba(16,185,129,0.15); color: #10B981; }
.detail-status.gap { background: rgba(245,158,11,0.15); color: #F59E0B; }
.detail-info { flex: 1; }
.detail-item { font-size: 26rpx; font-weight: 600; color: var(--text-primary); display: block; }
.detail-desc { font-size: 22rpx; color: var(--text-tertiary); }

/* 操作栏 */
.action-bar { display: flex; gap: var(--gap-md); margin-top: var(--gap-lg); }
.action-bar .btn { flex: 1; height: 88rpx; font-size: 28rpx; }

.btn:active { opacity: 0.9; transform: scale(0.98); }
.btn-primary:active { opacity: 0.9; transform: scale(0.98); }
