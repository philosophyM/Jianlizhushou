<!-- 首页 -->
<view class="page">
  <!-- 顶部渐变区域 -->
  <view class="hero-section">
    <view class="hero-bg"></view>
    <view class="hero-content">
      <text class="hero-title">简历助手</text>
      <text class="hero-subtitle">AI 智能定制简历 · 精准匹配每一份工作</text>
      <view class="hero-stats">
        <view class="stat-item">
          <text class="stat-num">定制</text>
          <text class="stat-label">每家公司独立生成</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">精准</text>
          <text class="stat-label">AI 匹配岗位需求</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">高效</text>
          <text class="stat-label">3分钟快速生成</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快速操作 -->
  <view class="quick-actions">
    <view class="section-title">快速开始</view>
    <view class="action-grid">
      <view class="action-card" bindtap="goToJobAnalysis">
        <view class="action-icon" style="background: rgba(74,108,247,0.1);">
          <text class="icon-text">📋</text>
        </view>
        <text class="action-title">粘贴招聘信息</text>
        <text class="action-desc">复制招聘信息，AI 智能解析</text>
      </view>
      <view class="action-card" bindtap="goToAssessment">
        <view class="action-icon" style="background: rgba(124,58,237,0.1);">
          <text class="icon-text">🧠</text>
        </view>
        <text class="action-title">职业测评</text>
        <text class="action-desc">科学测评，找到适合的职业</text>
      </view>
      <view class="action-card" bindtap="goToProfile">
        <view class="action-icon" style="background: rgba(16,185,129,0.1);">
          <text class="icon-text">👤</text>
        </view>
        <text class="action-title">完善资料</text>
        <text class="action-desc">填写个人基本信息</text>
      </view>
      <view class="action-card" bindtap="goToHistory">
        <view class="action-icon" style="background: rgba(245,158,11,0.1);">
          <text class="icon-text">📚</text>
        </view>
        <text class="action-title">历史记录</text>
        <text class="action-desc">查看已生成的简历</text>
      </view>
    </view>
  </view>

  <!-- 工作流程 -->
  <view class="workflow">
    <view class="section-title">使用流程</view>
    <view class="workflow-steps">
      <view class="step-item">
        <view class="step-number">1</view>
        <view class="step-content">
          <text class="step-title">完善个人资料</text>
          <text class="step-desc">填写基本信息、工作经历和教育背景</text>
        </view>
      </view>
      <view class="step-connector"></view>
      <view class="step-item">
        <view class="step-number">2</view>
        <view class="step-content">
          <text class="step-title">完成职业测评</text>
          <text class="step-desc">了解自己的职业兴趣和适合方向</text>
        </view>
      </view>
      <view class="step-connector"></view>
      <view class="step-item">
        <view class="step-number">3</view>
        <view class="step-content">
          <text class="step-title">粘贴招聘信息</text>
          <text class="step-desc">从招聘平台复制职位要求粘贴分析</text>
        </view>
      </view>
      <view class="step-connector"></view>
      <view class="step-item">
        <view class="step-number">4</view>
        <view class="step-content">
          <text class="step-title">生成针对性简历</text>
          <text class="step-desc">AI智能定制，高匹配度简历即刻生成</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 特性介绍 -->
  <view class="features">
    <view class="section-title">核心功能</view>
    <view class="feature-grid">
      <view class="feature-item">
        <text class="feature-icon">🎯</text>
        <text class="feature-name">精准匹配</text>
        <text class="feature-desc">深入分析 JD 要求，针对性优化简历内容</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">🧬</text>
        <text class="feature-name">科学测评</text>
        <text class="feature-desc">基于霍兰德、大五人格等权威心理测评</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">🔄</text>
        <text class="feature-name">多版本管理</text>
        <text class="feature-desc">针对不同公司生成不同版本，随时切换</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">📤</text>
        <text class="feature-name">轻松分享</text>
        <text class="feature-desc">支持导出和直接在微信中分享简历</text>
      </view>
    </view>
  </view>
</view>
