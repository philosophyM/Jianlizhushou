.page { padding-bottom: 120rpx; }
.container { padding: var(--gap-md); }
.hero-text { text-align: center; padding: var(--gap-md) 0; }
.hero-title { font-size: 40rpx; font-weight: 700; color: var(--text-primary); display: block; }
.hero-desc { font-size: 26rpx; color: var(--text-secondary); margin-top: 12rpx; }
.card { background: white; border-radius: 16rpx; padding: var(--gap-md); margin-bottom: var(--gap-md); box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
.section-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); margin-bottom: var(--gap-md); padding-left: var(--gap-sm); border-left: 6rpx solid #4A6CF7; }
.btn-primary { background: linear-gradient(135deg, #4A6CF7, #3451D1); color: white; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-weight: 600; }
.btn-large { width: 100%; height: 96rpx; font-size: 32rpx; margin-top: var(--gap-lg); }
.btn-secondary { background: var(--bg-primary); color: var(--text-primary); border: 2rpx solid var(--border); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 600; }

/* 配置区 */
.config-item { margin-bottom: var(--gap-lg); }
.config-label { font-size: 28rpx; font-weight: 600; color: var(--text-primary); display: block; margin-bottom: var(--gap-sm); }
.config-options { display: flex; gap: var(--gap-sm); }
.config-option { flex: 1; padding: 20rpx 16rpx; border: 2rpx solid var(--border); border-radius: var(--radius-md); text-align: center; font-size: 24rpx; transition: all 0.2s; }
.config-option.active { border-color: #4A6CF7; background: rgba(74,108,247,0.05); color: #4A6CF7; font-weight: 600; }
.option-icon { display: block; font-size: 32rpx; margin-bottom: 4rpx; }
.option-text { font-size: 22rpx; }
.config-switches { }
.switch-item { display: flex; justify-content: space-between; align-items: center; padding: var(--gap-sm) 0; }

/* 生成动画 */
.generating-state { display: flex; flex-direction: column; align-items: center; padding: var(--gap-xl) 0; }
.generating-animation { display: flex; gap: 8rpx; margin-bottom: var(--gap-lg); }
.bar { width: 12rpx; height: 48rpx; background: linear-gradient(180deg, #4A6CF7, #7C3AED); border-radius: 6rpx; animation: barPulse 1s infinite; }
.bar.delay1 { animation-delay: 0.1s; height: 64rpx; }
.bar.delay2 { animation-delay: 0.2s; height: 80rpx; }
.bar.delay3 { animation-delay: 0.3s; height: 64rpx; }
@keyframes barPulse { 0%, 100% { opacity: 0.5; transform: scaleY(0.8); } 50% { opacity: 1; transform: scaleY(1); } }
.generating-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); margin-bottom: var(--gap-sm); }
.generating-desc { font-size: 26rpx; color: var(--text-tertiary); margin-bottom: var(--gap-sm); }
.generating-tip { font-size: 24rpx; color: var(--primary); }

/* 成功 */
.success-banner { background: linear-gradient(135deg, #10B981, #059669); border-radius: var(--radius-lg); padding: var(--gap-lg); text-align: center; margin-bottom: var(--gap-md); }
.success-icon { font-size: 64rpx; display: block; margin-bottom: var(--gap-sm); }
.success-title { font-size: 36rpx; font-weight: 700; color: white; display: block; }
.success-desc { font-size: 26rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; display: block; }

/* 简历摘要 */
.summary-text { font-size: 26rpx; color: var(--text-secondary); line-height: 1.6; }
.exp-list { display: flex; flex-direction: column; gap: var(--gap-md); }
.exp-card { border-left: 4rpx solid #4A6CF7; padding-left: var(--gap-md); }
.exp-company { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.exp-title { font-size: 24rpx; color: var(--text-secondary); margin-bottom: 8rpx; }
.exp-desc { font-size: 24rpx; color: var(--text-tertiary); line-height: 1.5; }
.skills-list { display: flex; flex-wrap: wrap; gap: var(--gap-sm); }
.skill-tag { background: rgba(74,108,247,0.1); color: #4A6CF7; padding: 8rpx 24rpx; border-radius: 20rpx; font-size: 24rpx; }

/* 操作栏 */
.action-bar { display: flex; gap: var(--gap-md); margin-top: var(--gap-lg); }
.action-bar .btn { flex: 1; height: 88rpx; font-size: 28rpx; }
.btn:active { opacity: 0.9; transform: scale(0.98); }
.btn-primary:active { opacity: 0.9; transform: scale(0.98); }
